{
  "name": "opencode-android-app",
  "description": "Android client for OpenCode",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "license": "MIT",
  "workspaces": ["app", "ui", "sdk", "core", "android"],
  "scripts": {
    "dev": "bun run --cwd app dev",
    "build": "bun run --cwd app build",
    "build:android": "VITE_PLATFORM=android bun run --cwd app build && cd android && npx cap sync android",
    "typecheck": "bun turbo typecheck"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.9",
    "turbo": "2.8.13",
    "typescript": "5.8.2"
  },
  "trustedDependencies": [
    "esbuild",
    "node-pty",
    "protobufjs",
    "tree-sitter",
    "tree-sitter-bash",
    "tree-sitter-powershell",
    "web-tree-sitter",
    "electron"
  ],
  "overrides": {
    "@types/bun": "1.3.13",
    "@types/node": "24.12.2"
  },
  "patchedDependencies": {
    "solid-js@1.9.10": "patches/solid-js@1.9.10.patch",
    "virtua@0.49.1": "patches/virtua@0.49.1.patch"
  }
}